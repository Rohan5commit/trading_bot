{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SignalOutput",
  "type": "object",
  "required": [
    "symbol",
    "timestamp",
    "action",
    "entry_assumption",
    "confidence",
    "position_size",
    "rationale_tags",
    "expected_holding_period"
  ],
  "properties": {
    "symbol": {"type": "string"},
    "timestamp": {"type": "string", "format": "date-time"},
    "action": {"type": "string", "enum": ["BUY", "HOLD", "SELL"]},
    "entry_assumption": {"type": "string", "enum": ["next_open", "next_close"]},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "position_size": {"type": "number", "minimum": 0, "maximum": 1},
    "entry_price": {"type": "number"},
    "rationale_tags": {"type": "array", "items": {"type": "string"}},
    "expected_holding_period": {"type": "string"}
  }
}
